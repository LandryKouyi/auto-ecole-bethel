# Copier ce fichier en .env et remplir les valeurs.

# Port d'écoute (Render fournit PORT automatiquement)
PORT=3000

# Chemin de la base SQLite. En prod Render, pointer vers le disque persistant, ex: /var/data/autoecole.db
DB_PATH=./data/autoecole.db

# Secret de signature des jetons JWT (mettre une longue chaîne aléatoire en prod)
JWT_SECRET=change-moi-en-production-avec-une-longue-chaine-aleatoire

# --- E-Billing / SHAP (Digitech Africa) : Mobile Money Gabon (Airtel Money, Moov Money) ---
# Rail de paiement RÉEL au Gabon. Identifiants marchands fournis par Digitech Africa.
EBILLING_USERNAME=
EBILLING_SHARED_KEY=
# URLs par défaut (production billing-easy) — ne changer que si Digitech le demande.
EBILLING_SERVER_URL=https://stg.billing-easy.com/api/v1/merchant/e_bills
EBILLING_POST_URL=https://staging.billing-easy.net
# URL publique de l'app (pour la notification E-Billing). Ex: https://auto-ecole-bethel.onrender.com
PUBLIC_URL=http://localhost:3000

# Compte admin créé automatiquement au premier démarrage (seed)
ADMIN_EMAIL=admin@autoecole.ga
ADMIN_PASSWORD=admin2026

# --- Accès développement ---
# DEV_ACCESS=1 active le bouton "🔧 Gestion (dev)" sur la vitrine + la connexion
# admin automatique via /app?dev=1 (pratique pendant le développement).
# ⚠️ NE JAMAIS mettre cette variable en PRODUCTION : laisser vide/absent → l'accès
# à la gestion se fait uniquement par l'écran de connexion (email + mot de passe).
DEV_ACCESS=1
